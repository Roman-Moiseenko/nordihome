{
    "name": "laravel/laravel",
    "type": "project",
    "description": "The skeleton application for the Laravel framework.",
    "keywords": ["laravel", "framework"],
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "ext-curl": "*",
        "ext-dom": "*",
        "ext-iconv": "*",
        "ext-pdo": "*",
        "ext-simplexml": "*",
        "ext-zip": "*",
        "alexwebprog/laravel-notification-channel-max": "^2.1",
        "diglactic/laravel-breadcrumbs": "^10.0",
        "giggsey/libphonenumber-for-php": "^9.0",
        "guzzlehttp/guzzle": "^7.2",
        "hflabs/dadata": "^24.4",
        "inertiajs/inertia-laravel": "^2.0",
        "intervention/image": "^2.7",
        "kalnoy/nestedset": ">=6.0.0 <6.0.7",
        "laracasts/flash": "^3.2",
        "laravel-notification-channels/telegram": "^7.0",
        "laravel/framework": "^v12.64.0",
        "laravel/sanctum": "^4.0",
        "laravel/tinker": "^2.8",
        "laravel/ui": "^4.2",
        "livewire/livewire": "^3.5",
        "mpdf/mpdf": "^v8.2.5",
        "nesbot/carbon": "^3.8",
        "phpoffice/phpspreadsheet": "^3.6.0",
        "ryangjchandler/blade-cache-directive": "^1.1",
        "spatie/laravel-data": "^4.23",
        "spatie/laravel-permission": "^8.0",
        "tightenco/ziggy": "^v2.4.1",
        "webklex/laravel-imap": "^6.1"
    },
    "require-dev": {
        "barryvdh/laravel-debugbar": "^v3.14.7",
        "barryvdh/laravel-ide-helper": "^v3.2.2",
        "fakerphp/faker": "^1.9.1",
        "kadevland/laravel-easy-modules": "^1.0",
        "laravel/pint": "^v1.18.2",
        "mockery/mockery": "^1.4.4",
        "nunomaduro/collision": "^8.5",
        "phpunit/phpunit": "^11.4.3",
        "spatie/laravel-ignition": "^2.0"
    },
    "config": {
        "policy.advisories.ignore-id": [
            "PKSA-m5cs-t1y6-qpcs",
            "PKSA-3r5d-mb8f-1qw9",
            "PKSA-mdq4-51ck-6kdq",
            "PKSA-8qx3-n5y5-vvnd",
            "PKSA-q46n-4fdk-zjr4",
            "PKSA-qzrn-rnz3-85w1",
            "PKSA-w7xr-vk7n-rstm",
            "PKSA-p3rx-dfwp-73ny",
            "PKSA-ckwp-rt7t-c46m",
            "PKSA-4npr-btr6-zhny",
            "PKSA-njrm-6dtg-m2pc",
            "PKSA-985r-hryy-555b",
            "PKSA-zwc5-qtrz-zm1n"
        ],
        "policy.advisories.block": false,
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        },
        "files": [
            "app/Http/Helpers.php",
            "app/Modules/Base/Helpers/function.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },

    "minimum-stability": "stable",
    "prefer-stable": true
}
